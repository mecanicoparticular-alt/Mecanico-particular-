{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "TallerConfig": {
      "title": "TallerConfig",
      "description": "Configuration settings for the workshop",
      "type": "object",
      "properties": {
        "nombreComercial": { "type": "string" },
        "razonSocial": { "type": "string" },
        "cif": { "type": "string" },
        "direccion": { "type": "string" },
        "telefono": { "type": "string" },
        "precioManoObra": { "type": "number" },
        "textoLegal": { "type": "string" },
        "logoUrl": { "type": "string" },
        "geminiApiKey": { "type": "string" }
      },
      "required": ["nombreComercial", "direccion", "telefono"]
    },
    "Cliente": {
      "title": "Cliente",
      "description": "Client details and active workshop state",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "dni": { "type": "string" },
        "telefono": { "type": "string" },
        "matricula": { "type": "string" },
        "marcaModelo": { "type": "string" },
        "enTaller": { "type": "boolean" },
        "estadoActual": { "type": "string" },
        "historial": { "type": "array" },
        "userId": { "type": "string" }
      },
      "required": ["id", "nombre", "matricula", "userId"]
    },
    "DocumentoDraft": {
      "title": "DocumentoDraft",
      "description": "Invoice or budget document generated by the workshop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cliente": { "type": "string" },
        "dni": { "type": "string" },
        "telefono": { "type": "string" },
        "matricula": { "type": "string" },
        "vehiculo": { "type": "string" },
        "items": { "type": "array" },
        "fecha": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "cliente", "matricula", "userId"]
    },
    "AveriaResuelta": {
      "title": "AveriaResuelta",
      "description": "Resolved issue shared within the global community",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "titulo": { "type": "string" },
        "sintomas": { "type": "string" },
        "solucion": { "type": "string" },
        "autor": { "type": "string" },
        "verificado": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "titulo", "solucion", "autor"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/taller_config/{userId}": {
      "schema": "TallerConfig",
      "description": "Workshop configuration per user"
    },
    "/clientes/{clienteId}": {
      "schema": "Cliente",
      "description": "Clients registered in the workshop"
    },
    "/documentos/{documentoId}": {
      "schema": "DocumentoDraft",
      "description": "Invoices and budgets created by users"
    },
    "/comunidad/{averiaId}": {
      "schema": "AveriaResuelta",
      "description": "Community database of resolved issues"
    }
  }
}
